# Prevent CRLF in shebang-driven scripts (WSL can interpret `bash\r`).
*.sh text eol=lf

# Node tooling scripts are sometimes executed directly via shebang.
tools/scripts/*.mjs text eol=lf
packages/content-schema/benchmarks/*.mjs text eol=lf

# TS entrypoints executed via `tsx` shebang.
tools/runtime-sim/src/index.ts text eol=lf
tools/economy-verification/src/index.ts text eol=lf
tools/content-schema-cli/src/compile.ts text eol=lf
tools/content-schema-cli/src/generate.ts text eol=lf

# Checked-in package build artifacts are generated with LF line endings.
packages/*/dist/**/*.js text eol=lf
packages/*/dist/**/*.mjs text eol=lf
packages/*/dist/**/*.cjs text eol=lf
packages/*/dist/**/*.d.ts text eol=lf
packages/*/dist/**/*.map text eol=lf
packages/*/dist/**/*.json text eol=lf
packages/*/dist/**/*.html text eol=lf
packages/*/dist/**/*.css text eol=lf
